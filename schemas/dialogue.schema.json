{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/dialogue.schema.json",
  "title": "Dialogue bank with state-conditioned slots",
  "description": "A bank holds every line a speaker can say. 'slots' assign nodes to game states: evaluated top-down, first match wins; a slot with an 'id' is addressable directly (map onEnter, quest startDialogue). Story writing = adding nodes and pointing slots at them.",
  "type": "object",
  "required": ["id", "kind", "speaker", "slots", "nodes"],
  "properties": {
    "id": { "type": "string", "pattern": "^dlgbank:[a-z0-9-]+$" },
    "kind": { "const": "dialogue-bank" },
    "speaker": { "type": "string", "pattern": "^(char:[a-z0-9-]+|by-character)$" },
    "portraitOverride": { "type": "string" },
    "slots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["node"],
        "properties": {
          "id": { "type": "string", "description": "Addressable slot name for direct invocation." },
          "when": {
            "type": "object",
            "properties": {
              "quest": { "type": "string", "pattern": "^quest:[a-z0-9-]+$" },
              "stage": { "type": "string" },
              "stageIn": { "type": "array", "items": { "type": "string" } },
              "flag": { "type": "string", "pattern": "^flag:[a-z0-9-]+$" },
              "notFlag": { "type": "string", "pattern": "^flag:[a-z0-9-]+$" }
            }
          },
          "default": { "type": "boolean" },
          "node": { "type": "string" }
        }
      }
    },
    "nodes": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["lines", "emits"],
        "properties": {
          "lines": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
          "opensShop": { "type": "string", "pattern": "^shop:[a-z0-9-]+$" },
          "choices": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "text"],
              "properties": {
                "id": { "type": "string" },
                "text": { "type": "string" },
                "goto": {
                  "type": "string",
                  "description": "Optional next node in this bank, for branching trees."
                }
              }
            }
          },
          "emits": {
            "type": "string",
            "pattern": "^dlg:[a-z0-9.-]+$",
            "description": "Event fired when the node finishes ('<event>:seen') or a choice is taken ('<event>:<choiceId>'). Quests listen for these."
          }
        }
      }
    }
  }
}
