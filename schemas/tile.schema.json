{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/tile.schema.json",
  "title": "Tile primitive",
  "type": "object",
  "required": ["id", "kind", "solid", "koota"],
  "properties": {
    "id": { "type": "string", "pattern": "^tile:[a-z0-9-]+$" },
    "kind": { "const": "tile" },
    "variantOf": { "type": "string", "pattern": "^tile:[a-z0-9-]+$" },
    "solid": { "type": "boolean" },
    "baseColor": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Solid base fill drawn UNDER a sheet overlay. The roguelike terrain cells are ~50%-alpha dither/cobble overlays meant to sit on a base color (the .pix model: base + scattered detail). A tile with baseColor + sheet renders the base rect then the cropped overlay on top — real PNG ground texture over a clean readable base."
    },
    "layers": { "$ref": "./draw-ops.schema.json#/$defs/opList" },
    "rows": {
      "type": "array",
      "items": { "type": "string", "minLength": 16, "maxLength": 16 },
      "minItems": 16,
      "maxItems": 16
    },
    "sheet": {
      "type": "object",
      "required": ["image", "x", "y", "w", "h"],
      "properties": {
        "image": { "type": "string", "pattern": "^[a-z0-9/_.-]+\\.png$" },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 },
        "field": {
          "type": "object",
          "description": "A multi-cell GROUND FIELD: the (x,y) rect is the top-left of a cols×rows block of 16px cells in the PNG, and the renderer samples a per-(col,row) cell from that block (wrapping) so the map reproduces the pack's large seamless dithered ground instead of tiling one 16px cell into visible seams. For dithered-fill terrain (The Ground pack).",
          "required": ["cols", "rows"],
          "properties": {
            "cols": { "type": "integer", "minimum": 1 },
            "rows": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "description": { "type": "string" },
    "koota": {
      "type": "object",
      "required": ["traits"],
      "properties": { "traits": { "type": "array", "items": { "type": "string" } } }
    }
  },
  "anyOf": [
    { "required": ["layers"] },
    { "required": ["rows"] },
    { "required": ["sheet"] },
    { "required": ["baseColor"] }
  ]
}
