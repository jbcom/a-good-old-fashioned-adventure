{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/tile.schema.json",
  "title": "Tile primitive",
  "type": "object",
  "required": ["id", "kind", "solid", "koota"],
  "properties": {
    "id": { "type": "string", "pattern": "^tile:[a-z0-9-]+$" },
    "kind": { "const": "tile" },
    "variantOf": { "type": "string", "pattern": "^tile:[a-z0-9-]+$" },
    "solid": { "type": "boolean" },
    "layers": { "$ref": "./draw-ops.schema.json#/$defs/opList" },
    "rows": {
      "type": "array",
      "items": { "type": "string", "minLength": 16, "maxLength": 16 },
      "minItems": 16,
      "maxItems": 16
    },
    "sheet": {
      "type": "object",
      "required": ["image", "x", "y", "w", "h"],
      "properties": {
        "image": { "type": "string", "pattern": "^[a-z0-9/_.-]+\\.png$" },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "w": { "type": "integer", "minimum": 1 },
        "h": { "type": "integer", "minimum": 1 },
        "field": {
          "type": "object",
          "description": "A multi-cell GROUND FIELD: the (x,y) rect is the top-left of a cols×rows block of w×h cells in the PNG, and the renderer samples a per-(col,row) cell from that block (wrapping) so a ground area reproduces the pack's variation instead of tiling one cell into visible seams. The cell size (w,h) is the source's NATIVE resolution (e.g. 64 for the RPG Tiles Vector pack) — tiles bake at native res so the texture never magnifies into a flat blob.",
          "required": ["cols", "rows"],
          "properties": {
            "cols": { "type": "integer", "minimum": 1 },
            "rows": { "type": "integer", "minimum": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "description": { "type": "string" },
    "koota": {
      "type": "object",
      "required": ["traits"],
      "properties": { "traits": { "type": "array", "items": { "type": "string" } } }
    }
  },
  "anyOf": [{ "required": ["layers"] }, { "required": ["rows"] }, { "required": ["sheet"] }]
}
