{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/enemy-archetype.schema.json",
  "title": "Enemy archetype (one file per archetype, globbed into enemies.archetypes)",
  "type": "object",
  "required": ["id", "name", "sprite", "palette", "hp", "speed", "hitbox", "behavior"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "sprite": { "type": "string" },
    "palette": { "type": "string" },
    "family": { "type": "string" },
    "hp": { "type": "number", "minimum": 1 },
    "speed": { "type": "number", "minimum": 0 },
    "hitbox": {
      "type": "object",
      "required": ["w", "h"],
      "properties": {
        "w": { "type": "number" },
        "h": { "type": "number" }
      }
    },
    "behavior": {
      "enum": ["patrol", "chase", "caster", "turret", "boss", "ambush", "guard"]
    },
    "touchHarmless": { "type": "boolean" },
    "knockbackImmune": { "type": "boolean" },
    "miniboss": { "type": "boolean" },
    "relentless": { "type": "boolean" },
    "ambush": { "type": "object" },
    "guard": { "type": "object" },
    "caster": { "type": "object" },
    "turret": { "type": "object" },
    "boss": { "type": "object" }
  }
}
