{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/character.schema.json",
  "title": "Cast registry",
  "type": "object",
  "required": ["kind", "characters"],
  "properties": {
    "kind": { "const": "cast" },
    "characters": {
      "type": "object",
      "propertyNames": { "pattern": "^char:[a-z0-9-]+$" },
      "additionalProperties": {
        "type": "object",
        "required": ["name", "role"],
        "properties": {
          "name": { "type": "string" },
          "role": { "enum": ["player", "npc", "voice"] },
          "sprite": { "type": "string", "pattern": "^sprite:[a-z0-9-]+$" },
          "palette": { "type": "string", "pattern": "^(palette:[a-z0-9-]+|by-class)$" },
          "portraitColor": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "dialogue": { "type": "string", "pattern": "^dlgbank:[a-z0-9-]+$" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
