{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jbcom/a-good-old-fashioned-adventure/schemas/shop.schema.json",
  "title": "Shop counter",
  "type": "object",
  "required": ["id", "kind", "name", "keeper", "currency", "listings"],
  "properties": {
    "id": { "type": "string", "pattern": "^shop:[a-z0-9-]+$" },
    "kind": { "const": "shop" },
    "name": { "type": "string" },
    "keeper": { "type": "string", "pattern": "^char:[a-z0-9-]+$" },
    "currency": { "type": "string", "pattern": "^item:[a-z0-9-]+$" },
    "buySfx": { "type": "string" },
    "sellSfx": { "type": "string" },
    "denySfx": { "type": "string" },
    "listings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "item", "label", "description", "buyPrice", "sellPrice"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "item": { "type": "string", "pattern": "^item:[a-z0-9-]+$" },
          "label": { "type": "string" },
          "description": { "type": "string" },
          "buyPrice": { "type": "integer", "minimum": 0 },
          "sellPrice": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
