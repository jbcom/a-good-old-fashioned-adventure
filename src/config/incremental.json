{
  "$schema": "../../schemas/config.schema.json",
  "loop": {
    "id": "princess-rescue",
    "name": "Princess Rescue",
    "startClass": "knight",
    "routeShape": "south-to-north",
    "playerAnchor": "south",
    "princessAnchor": "north",
    "guardian": "dragon",
    "startMap": "map:rescue-route",
    "coreRunRequiresCastleInterior": false,
    "resultsMode": "upgrade-graph",
    "targetGameplayAreaPercentPhone": 80,
    "rescueRadius": 48
  },
  "currencies": {
    "coins": {
      "label": "Coins",
      "shortLabel": "C",
      "relativeVolume": "common",
      "primarySources": ["enemy-defeated", "road-skirmish", "repeatable-route"],
      "spendRoles": ["ranked-upgrades", "class-tracks", "adversarial-risk", "practical-upgrades"],
      "hudPriority": 1
    },
    "roses": {
      "label": "Roses",
      "shortLabel": "R",
      "relativeVolume": "rare",
      "rarityRatioAgainstCoins": 0.18,
      "primarySources": ["princess-rescued", "objective-mastered", "road-mastered"],
      "spendRoles": ["major-unlocks", "new-classes", "new-maps", "new-bosses", "princess-boons"],
      "hudPriority": 2
    }
  },
  "runRewards": {
    "enemyDefeated": {
      "currency": "coins",
      "base": 3,
      "eliteBonus": 7
    },
    "roadTravelled": {
      "currency": "coins",
      "perSegment": 2
    },
    "objectiveCleared": {
      "currency": "roses",
      "base": 1
    },
    "princessRescued": {
      "currency": "roses",
      "base": 3
    },
    "minibossDefeated": {
      "currency": "coins",
      "base": 15
    },
    "dragonGems": {
      "currency": "gems",
      "base": 4
    }
  },
  "upgradeGraph": {
    "root": "upgrade:first-vow",
    "ringOrder": ["vows", "characters", "encounters", "roads", "castle"],
    "trackEntries": {
      "vows": "upgrade:first-vow",
      "characters": "upgrade:knight-vigor",
      "encounters": "upgrade:dragon-wake",
      "roads": "upgrade:oldwood-bend",
      "castle": "upgrade:castle-candle-loop"
    },
    "lockedTracks": ["castle"]
  },
  "classes": {
    "starting": "knight",
    "unlockable": [
      "ranger",
      "wizard",
      "rogue",
      "bard",
      "sorcerer",
      "priest",
      "warlock",
      "barbarian",
      "dread-knight",
      "shaman",
      "stormcaller"
    ]
  },
  "routePacks": [
    {
      "id": "oldwood",
      "label": "Oldwood Bend",
      "maps": ["map:oldwood-forest"],
      "role": "first branching road with forest pressure and safe-passage objectives"
    },
    {
      "id": "deep-forest",
      "label": "Thornwood Dusk",
      "maps": ["map:deep-forest"],
      "role": "rose-awarding road mastery and inhabited woodland scenes"
    },
    {
      "id": "sunken-road",
      "label": "Sunken Road",
      "maps": ["map:sunken-road", "map:desert-ruins"],
      "role": "hazard shortcut, desert silhouettes, and optional ruin objectives"
    },
    {
      "id": "castle-approach",
      "label": "Siege Approach",
      "maps": ["map:castle-approach", "map:castle-yard"],
      "role": "threshold pressure before the dragon rescue"
    },
    {
      "id": "castle-interior",
      "label": "Candlelit Castle Loop",
      "maps": ["map:castle-hall", "map:castle-library", "map:castle-armory"],
      "role": "rose-gated side loop with scribe and heraldic objectives"
    }
  ],
  "mapDag": {
    "comment": "Successive map progression (docs/RAIL-COMMAND.md §Map DAG — no jumping): an ordered list of route maps. A run plays the player's furthest UNLOCKED map; clearing it (felling the kin boss) unlocks the next via its gem major. The princess always sits at the last unlocked map; the castle node relocates the castle to the last map and the princess into it. Side maps (interiors) hang off their route map and are not part of the linear spine.",
    "order": [
      "map:rescue-route",
      "map:oldwood-forest",
      "map:deep-forest",
      "map:sunken-road",
      "map:castle-approach",
      "map:castle-hall"
    ],
    "princessAtLastUnlocked": true,
    "castleNode": "upgrade:castle-candle-loop",
    "castleMap": "map:castle-hall"
  },
  "mapLairs": {
    "map:oldwood-forest": {
      "theme": "captured-village",
      "rooms": [
        "map:village",
        "map:village-house",
        "map:village-shop",
        "map:village-stable",
        "map:village-tavern"
      ]
    },
    "map:deep-forest": {
      "theme": "thornwood-hollow",
      "rooms": ["map:thornwood-grove", "map:thornwood-warren", "map:thornwood-deep"]
    },
    "map:sunken-road": {
      "theme": "sunken-crypt",
      "rooms": ["map:desert-ruins", "map:castle-dungeon", "map:crypt-vault"]
    }
  }
}
