{
  "$schema": "../../schemas/config.schema.json",
  "language": {
    "id": "errant-storybook",
    "name": "Errant Storybook",
    "summary": "knights-errant in an old illustrated tale; vellum, ink, rubric, ivy, and aged brass over an FF7-era HD-2D stage"
  },
  "typography": {
    "display": {
      "family": "\"IM Fell English SC\", \"EB Garamond\", Georgia, serif"
    },
    "body": {
      "family": "\"EB Garamond\", Georgia, \"Times New Roman\", serif"
    },
    "numeric": {
      "family": "\"Alegreya Sans\", \"Trebuchet MS\", system-ui, sans-serif"
    }
  },
  "font": {
    "family": "\"IM Fell English SC\", \"EB Garamond\", Georgia, serif",
    "fallback": "Georgia, serif"
  },
  "theme": {
    "background": "#17110b",
    "panel": "rgba(241, 224, 185, 0.88)",
    "panelStrong": "rgba(249, 236, 202, 0.96)",
    "panelSoft": "rgba(92, 64, 42, 0.22)",
    "panelBorder": "#8a5f32",
    "panelEdge": "#3d2a1b",
    "shell": "#3b2918",
    "textPrimary": "#25180f",
    "textBody": "#4e3925",
    "textMuted": "#7a654c",
    "accentGold": "#b07a2c",
    "accentGreen": "#315f3b",
    "accentGreenDark": "#1e3d2a",
    "accentRed": "#9f2f28",
    "accentRedDark": "#5b211c",
    "accentBlue": "#496f86",
    "accentPink": "#a86569",
    "hpBar": "#9f2f28",
    "xpBar": "#315f3b"
  },
  "floaterColors": {
    "damage": "#ff3355",
    "xp": "#315f3b",
    "heal": "#9f2f28",
    "gold": "#b07a2c",
    "maxHp": "#a86569",
    "attack": "#496f86"
  },
  "controls": {
    "keyboard": {
      "up": ["ArrowUp", "w"],
      "down": ["ArrowDown", "s"],
      "left": ["ArrowLeft", "a"],
      "right": ["ArrowRight", "d"],
      "actionA": ["j", " "],
      "actionB": ["k", "Shift"]
    },
    "touch": { "dpad": true, "faceButtons": ["B", "A"] }
  }
}
