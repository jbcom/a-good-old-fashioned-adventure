{
  "$schema": "../../../../schemas/dialogue.schema.json",
  "id": "dlgbank:woodcutter",
  "kind": "dialogue-bank",
  "speaker": "char:woodcutter",
  "slots": [
    { "when": { "quest": "quest:broken-bridge", "stage": "find-woodcutter" }, "node": "request" },
    { "when": { "quest": "quest:broken-bridge", "stage": "cull-orcs" }, "node": "progress" },
    { "when": { "quest": "quest:broken-bridge", "stage": "report-back" }, "node": "repaired" },
    { "default": true, "node": "smalltalk" }
  ],
  "nodes": {
    "request": {
      "lines": [
        "Halt traveler! The river bridge is broken, and vicious Forest Orcs block the path. Cull down 4 Forest Orcs and I will fix the bridge!"
      ],
      "choices": [{ "id": "accepted", "text": "I'll handle it." }],
      "emits": "dlg:woodcutter.request"
    },
    "progress": {
      "lines": [
        "I need 4 Orcs cleared! You've only stopped {quest:broken-bridge.orcsKilled}/4 of them."
      ],
      "emits": "dlg:woodcutter.progress"
    },
    "repaired": {
      "lines": [
        "Outstanding! I've fully repaired the river bridge. Safe travels through the sandy beaches ahead!"
      ],
      "emits": "dlg:woodcutter.repaired"
    },
    "smalltalk": {
      "lines": ["The path is clear. May safety follow your path."],
      "emits": "dlg:woodcutter.smalltalk"
    }
  }
}
