@pixel-sheet v1
# World effect art: pickups and projectiles. Nothing in the world may render
# as a bare colored quad — every drop and bolt gets an authored silhouette.

@sprite sprite:pickup-orb
description XP orb drop: green glass bead with a window shine.
grid 8x8
anchor 4,8
channels X,E,e,W
palette palette:base
animations idle=anim:pickup-bob
traits Transform,Sprite,DepthSorted
rows
..XXX...
.XEEEX..
XEEWEEX.
XEEEEEX.
XEeEEeX.
XeEEEeX.
.XeeeX..
..XXX...
@end

@sprite sprite:pickup-heart
description Heart drop: outlined storybook heart with a shine pixel.
grid 8x8
anchor 4,8
channels X,R,r,W
palette palette:base
animations idle=anim:pickup-bob
traits Transform,Sprite,DepthSorted
rows
.XX.XX..
XRRXRRX.
XRRRRRX.
XRrWrRX.
.XRrRX..
..XRX...
...X....
........
@end

