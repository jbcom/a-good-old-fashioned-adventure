{
  "$schema": "../../../schemas/sprite.schema.json",
  "id": "sprite:hero",
  "kind": "character-sprite",
  "description": "Universal 16x16 humanoid model. Knight, ranger, wizard, rogue, woodcutter, companions and skeletons are all palette swaps of this one grid.",
  "grid": { "w": 16, "h": 16 },
  "anchor": { "x": 8, "y": 16 },
  "rows": [
    "................",
    "......rrr.......",
    ".....rRRr.......",
    ".....rRRs.......",
    "....XSSSSSX.....",
    "....XsXWXsX.....",
    "....XSSSSSX.....",
    ".....XXSXX......",
    "....XXsSsXX.....",
    "...XsXXSXXsX....",
    "...XSS.s.SSW....",
    "..XXXS.s.SSX....",
    "..Xs.S.s.SSX....",
    "..XX.X.X.XXX....",
    ".....X.X........",
    "....XX.XX......."
  ],
  "recolorChannels": ["S", "s", "R", "r", "W", "F", "f", "X"],
  "defaultPalette": "palette:base",
  "facing": { "method": "mirror-x", "defaultDir": 1 },
  "animations": {
    "idle": "anim:idle",
    "walk": "anim:walk-bob",
    "hurt": "anim:hit-flash",
    "ghost": "anim:trail-fade"
  },
  "koota": {
    "traits": ["Transform", "Sprite", "Palette", "Facing", "Animator", "DepthSorted"]
  }
}
