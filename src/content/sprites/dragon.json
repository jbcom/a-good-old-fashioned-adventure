{
  "$schema": "../../../schemas/sprite.schema.json",
  "id": "sprite:dragon",
  "kind": "character-sprite",
  "description": "16x16 beast model. Orcs, the desert wyrm, and the shadow warlord boss are palette swaps of this grid.",
  "grid": { "w": 16, "h": 16 },
  "anchor": { "x": 8, "y": 16 },
  "rows": [
    "................",
    "......XeeX......",
    ".....XEEEXX.....",
    "Y...XEEYEXX.....",
    "YO.XXEEEXX......",
    "Y..XeeEEX.......",
    "...XeeEEX.......",
    "..XeeEEETX......",
    ".XXEEEEEeEX.....",
    ".XEEeeEEEEXX....",
    "..XEeeTeEEEX....",
    "..XETX.XEEEX....",
    "...XX..XEEeTX...",
    "........XXTEX...",
    "..........XX....",
    "................"
  ],
  "recolorChannels": ["E", "e", "T", "Y", "O", "X"],
  "defaultPalette": "palette:base",
  "facing": { "method": "mirror-x", "defaultDir": 1 },
  "animations": {
    "idle": "anim:idle",
    "walk": "anim:walk-bob",
    "hurt": "anim:hit-flash"
  },
  "koota": {
    "traits": ["Transform", "Sprite", "Palette", "Facing", "Animator", "DepthSorted"]
  }
}
