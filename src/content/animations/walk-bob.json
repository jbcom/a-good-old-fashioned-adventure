{
  "$schema": "../../../schemas/animation.schema.json",
  "id": "anim:walk-bob",
  "kind": "animation",
  "engine": "animejs",
  "target": "spriteOffset",
  "keyframes": [
    { "translateY": 0 },
    { "translateY": -2 },
    { "translateY": 0 }
  ],
  "duration": 283,
  "easing": "easeInOutSine",
  "loop": true,
  "description": "Movement bob: |sin(t/90ms)| * 2px lift while isMoving (period pi*90ms ≈ 283ms)."
}
