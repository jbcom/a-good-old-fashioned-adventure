{
  "name": "a-good-old-fashioned-adventure",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "vite",
    "db:generate": "drizzle-kit generate",
    "postinstall": "node scripts/copy-sql-wasm.mjs",
    "prebuild": "node scripts/copy-sql-wasm.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run --project unit",
    "test:browser": "pnpm test:browser:core && pnpm test:browser:journey",
    "test:browser:core": "vitest run --project browser --browser.fileParallelism=false --no-file-parallelism tests/browser/atlas.test.ts tests/browser/game-stage.test.tsx tests/browser/landing.test.tsx tests/browser/menu.test.tsx tests/browser/motion.test.ts tests/browser/smoke.test.tsx tests/browser/sqlite-web.test.ts tests/browser/stage.test.tsx tests/browser/web-persistence.test.tsx tests/browser/interiors.test.tsx tests/browser/shop.test.tsx tests/browser/desert-ruins.test.tsx tests/browser/village-market.test.tsx tests/browser/village-livelihood.test.tsx tests/browser/questline-depth.test.tsx",
    "test:browser:journey": "vitest run --project browser --browser.fileParallelism=false --no-file-parallelism tests/browser/playthrough.test.tsx tests/browser/exterior-route.test.tsx",
    "test:all": "pnpm test && pnpm test:browser",
    "cap:sync": "pnpm build && cap sync android",
    "cap:run:android": "pnpm cap:sync && cap run android"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor/android": "8.4.0",
    "@capacitor/core": "8.4.0",
    "@capacitor/device": "8.0.2",
    "@capacitor/preferences": "8.0.1",
    "@react-three/fiber": "^9.6.1",
    "ajv": "^8.20.0",
    "animejs": "^4.4.1",
    "drizzle-orm": "^0.45.2",
    "jeep-sqlite": "2.8.0",
    "koota": "^0.6.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "1.11.0",
    "three": "^0.184.0",
    "tone": "^15.1.22",
    "yuka": "^0.7.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@capacitor/cli": "8.4.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
    "@vitest/browser-playwright": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "playwright": "^1.60.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
