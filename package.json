  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/yuka": "^0.7.4",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/browser": "^4.1.8",
