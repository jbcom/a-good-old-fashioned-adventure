# ── agent-state cache (re-derivable; directive.md + decisions.ndjson stay tracked)
.agent-state/digest.md
.agent-state/cursor.md
.agent-state/.indexed-sha
.agent-state/.last-stop-sha
.agent-state/.last-compaction
.agent-state/.last-stop-fingerprint
.agent-state/batch.json
.claude/state/

# ── deps / build (arcade-game dialect)
node_modules/
dist/
tsconfig.tsbuildinfo
.local/
coverage/
*.log

# ── test scratch output (committed screenshots live in docs/evidence/)
tests/browser/*.png
tests/browser/__screenshots__/
.vitest-attachments/
.playwright-cli/
output/
output/playwright/

# ── secrets / local config
.env
.env.*

# ── purchased-asset working area: raw downloads, extractions, generated
#    aseprite masters and animation previews. NOTHING under raw-assets/ is
#    ever tracked — curated keepers are promoted to public/assets/ with a
#    MANIFEST.json entry (tests/unit/asset-manifest.test.ts enforces it).
raw-assets/
.itch-cache/

# ── OS noise
.DS_Store
Thumbs.db
